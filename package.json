{
  "name": "magic-color",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "core:lint": "cargo clippy --all-targets -- -D warnings",
    "core:fmt": "cargo fmt --check",
    "check": "bash exe/test",
    "bench": "tsx scripts/benchmark-generation.ts",
    "build:levels": "cargo build --release && ./target/release/bake --out bake-out && tsx scripts/emit-baked-from-rust.ts bake-out && tsx scripts/emit-provenance.ts && tsx scripts/archive-report.ts",
    "levels:provenance": "tsx scripts/emit-provenance.ts",
    "levels:archive": "tsx scripts/archive-report.ts",
    "levels:report": "tsx scripts/level-report.ts",
    "core:build": "cargo build --release",
    "core:test": "cargo test",
    "core:wasm": "wasm-pack build core --target web --out-dir ../src/game/core-pkg && rm -f src/game/core-pkg/.gitignore src/game/core-pkg/package.json src/game/core-pkg/README.md && tsx scripts/emit-core-stamp.ts",
    "report:dev": "vite --config vite.report.config.ts",
    "report:build": "tsc --noEmit && vite build --config vite.report.config.ts"
  },
  "dependencies": {
    "framer-motion": "^11.11.0",
    "lucide-react": "^1.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^25.0.1",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^2.1.4"
  }
}
