# EditorConfig — cross-editor baseline so the whitespace conventions the linters/formatters already
# enforce (2-space TS/JS/JSON/YAML, rustfmt's 4-space Rust) are applied as you type, in any editor.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Rust follows rustfmt (checked in the gate): 4-space indent.
[*.rs]
indent_size = 4

# Markdown: trailing whitespace can be a hard line break, so don't strip it.
[*.md]
trim_trailing_whitespace = false

# Makefile-style / tab-sensitive files, if any are added later.
[Makefile]
indent_style = tab
