#!/bin/bash
# The release gate (PLAN.md "Drift defense"), post-F6. The gameplay rules now live ONLY in the
# Rust core, so the cross-language drift checks retired: G2 (Rust→JS conformance trace) is gone,
# and G3/G4 became a native core SELF-CHECK of the emitted artifacts (they no longer replay under
# a second "JS rules" implementation, because there isn't one). What remains:
#
#   G1  vector conformance   cargo suites (rng + solver + difficulty vectors) + vitest rng pinning
#   G3  golden winning-line  core `verify` bin: each optimal line wins in exactly `optimal`
#   G4  committed statics    core `verify` bin: no degenerate, presence, bounds, round-trip, dedupe
#   G5  artifact freshness   committed .wasm crate-hash guard + adapter/live differentials (vitest)
#
# Runs in seconds; nonzero exit on any failure. Usage: exe/test [bake-out-dir] (default ./bake-out).
set -uo pipefail
cd "$(dirname "$0")/.."
export PATH="$HOME/.cargo/bin:$PATH"

BAKE_DIR="${1:-bake-out}"
FAILED=0

check() { # check <name> <command...>
  local name="$1"; shift
  if "$@" >/tmp/exe-test-$$.log 2>&1; then
    echo "PASS  $name"
  else
    echo "FAIL  $name"
    tail -20 /tmp/exe-test-$$.log | sed 's/^/      /'
    FAILED=1
  fi
}

echo "== release gate =="

check "G1 rust vectors (rng + solver + difficulty)" \
  cargo test --release --test rng_vectors --test conformance --test difficulty_vectors
check "G1 js pinning (rng vectors)" \
  npx vitest run src/game/rng.vectors.test.ts
check "G5 committed wasm freshness + adapter/live differential" \
  npx vitest run src/game/coreVersion.test.ts src/game/coreWasm.test.ts src/game/coreLive.test.ts

if [ -d "$BAKE_DIR" ] && [ -f "$BAKE_DIR/levels.json" ]; then
  check "G3+G4 golden lines + statics (core verify)" ./target/release/verify "$BAKE_DIR"
else
  echo "SKIP  G3-G4 (no bake artifacts at $BAKE_DIR — run: cargo build --release && ./target/release/bake --out $BAKE_DIR)"
fi

rm -f /tmp/exe-test-$$.log
if [ "$FAILED" -ne 0 ]; then
  echo "== GATE: FAIL =="
  exit 1
fi
echo "== GATE: PASS =="
