#!/usr/bin/env bash
# Thin launcher for the quality gate. The orchestration now lives in TypeScript (scripts/gate.ts,
# run via scripts/check.ts) so the SAME steps run locally and in CI (test parity) — see
# .github/workflows/ci.yml. This shim just ensures cargo is on PATH and hands off; `npm run check`
# runs the identical thing.
#
# Usage: exe/test [bake-out-dir] [--skip=id,id]
#   The baked-level self-check runs only when the bake dir has levels.json (default ./bake-out —
#   produce it with `npm run build:levels`). The e2e step runs only when a Chromium is installed.
set -euo pipefail
cd "$(dirname "$0")/.."
export PATH="$HOME/.cargo/bin:$PATH"
exec npx tsx scripts/check.ts "$@"
